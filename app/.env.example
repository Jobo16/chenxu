# Required — Slack app credentials (from api.slack.com/apps → Basic Information)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Required — PostgreSQL connection URL
DATABASE_URL=postgresql://morgenruf:morgenruf@db:5432/morgenruf

# Required — Flask session secret (generate: openssl rand -hex 32)
FLASK_SECRET_KEY=

# Required — Public URL where this instance is reachable (for OAuth redirects)
APP_URL=http://localhost:3000

# Optional — Dashboard access mode for internal deployments
# none = open the local/internal dashboard directly; key = require /dashboard/login?key=...
DASHBOARD_AUTH=none
DASHBOARD_ADMIN_KEY=

# Optional — Resend API key for welcome emails (https://resend.com)
RESEND_API_KEY=

# Optional — AI summary (set one to enable AI-generated daily summaries)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=

# Optional — Google Chat integration
# Service account JSON (single line, base64 or JSON string)
GOOGLE_CREDENTIALS=

# Optional — Feishu/Lark internal bot integration
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_EVENT_MODE=ws
FEISHU_VERIFICATION_TOKEN=
FEISHU_TEAM_ID=feishu
FEISHU_TEAM_NAME=飞书工作区
FEISHU_DEFAULT_CHAT_ID=
FEISHU_DEFAULT_CHAT_NAME=站会
FEISHU_CHANNELS=
FEISHU_ADMIN_OPEN_ID=
FEISHU_STANDUP_MEMBERS=
FEISHU_SCHEDULE_TIME=09:30
FEISHU_SCHEDULE_TZ=Asia/Shanghai
FEISHU_SCHEDULE_DAYS=mon,tue,wed,thu,fri
# JSON array, e.g. ["昨天完成了什么？","今天计划做什么？","有什么阻塞？"]
FEISHU_QUESTIONS_JSON=
FEISHU_AI_SUMMARY_ENABLED=false
FEISHU_AI_PROVIDER=openai

# Optional — Log level (DEBUG / INFO / WARNING)
LOG_LEVEL=INFO

# Optional — Port (default 3000)
PORT=3000

# Optional: Redis for persistent standup sessions (survives pod restarts)
# If not set, sessions are in-memory (lost on restart)
REDIS_URL=redis://localhost:6379/0

# Optional: Sentry DSN for error monitoring (https://sentry.io — free tier available)
SENTRY_DSN=
SENTRY_ENV=production
